<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dojo | Acceso al Sistema</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-body: #f1f5f9;
            --brand-dark: #0f172a;
            --accent: #6366f1;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --white: #ffffff;
            --error-bg: #fef2f2;
            --error-text: #991b1b;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .login-container {
            background-color: var(--white);
            width: 1000px;
            max-width: 100%;
            min-height: 600px;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            display: flex;
            overflow: hidden;
        }

        /* Lado Izquierdo - Branding */
        .brand-side {
            flex: 1;
            background-color: var(--brand-dark);
            background-image: radial-gradient(circle at 2px 2px, #1e293b 1px, transparent 0);
            background-size: 24px 24px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: var(--white);
            padding: 40px;
            text-align: center;
        }

        .logo-circle {
            width: 120px;
            height: 120px;
            background: var(--accent);
            border-radius: 30px; /* Estilo squircle moderno */
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 42px;
            font-weight: 800;
            margin-bottom: 24px;
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.4);
        }

        .brand-side h1 {
            font-size: 2rem;
            margin: 0;
            letter-spacing: -0.025em;
        }

        .brand-side p {
            color: #94a3b8;
            max-width: 250px;
            line-height: 1.6;
        }

        /* Lado Derecho - Formulario */
        .form-side {
            flex: 1.2;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-header {
            margin-bottom: 32px;
        }

        .form-header h2 {
            font-size: 1.875rem;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
        }

        .form-header p {
            color: var(--text-muted);
            margin: 8px 0 0 0;
        }

        /* Inputs Modernos */
        .input-wrapper {
            margin-bottom: 20px;
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            width: 18px;
        }

        .input-wrapper input {
            width: 100%;
            padding: 14px 14px 14px 44px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            font-size: 1rem;
            font-family: inherit;
            transition: all 0.2s;
            background-color: #f8fafc;
        }

        .input-wrapper input:focus {
            outline: none;
            border-color: var(--accent);
            background-color: var(--white);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

        .btn-submit {
            width: 100%;
            background-color: var(--brand-dark);
            color: var(--white);
            padding: 14px;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 10px;
        }

        .btn-submit:hover {
            background-color: #1e293b;
            transform: translateY(-1px);
        }

        .error-message {
            background-color: var(--error-bg);
            color: var(--error-text);
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid #fecaca;
        }

        /* Responsive */
        @media (max-width: 850px) {
            .login-container {
                flex-direction: column;
                width: 450px;
                min-height: auto;
            }
            .brand-side {
                padding: 40px 20px;
            }
            .form-side {
                padding: 40px 30px;
            }
            .logo-circle {
                width: 80px;
                height: 80px;
                font-size: 28px;
                border-radius: 20px;
            }
        }

        @media (max-width: 480px) {
            body { padding: 0; }
            .login-container {
                width: 100%;
                height: 100vh;
                border-radius: 0;
            }
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="brand-side">
            <div class="logo-circle">D</div>
            <h1>Dojo System</h1>
        </div>

        <div class="form-side">
            <div class="form-header">
                <h2>¡Bienvenido!</h2>
            </div>
            
            <% if (error) { %>
                <div class="error-message">
                    <i data-lucide="alert-circle" style="width: 18px;"></i>
                    <%= error %>
                </div>
            <% } %>
            
            <form action="/login" method="POST">
                <div class="input-wrapper">
                    <input type="text" name="nombre" placeholder="Nombre de usuario" required>
                </div>
                
                <div class="input-wrapper">
                    <input type="password" name="password" placeholder="Contraseña" required>
                </div>

                <button type="submit" class="btn-submit">
                    Acceder
                </button>
            </form>

            <div style="margin-top: 30px; text-align: center;">
                <p style="font-size: 0.8rem; color: var(--text-muted);">
                    © 2026 Dojo Software. Todos los derechos reservados.
                </p>
            </div>
        </div>
    </div>

    <script>
        // Inicializar iconos de Lucide
        lucide.createIcons();
    </script>
</body>
</html>